{
  "manifest_version": 3,
  "name": "fnOS Dock Bottom",
  "version": "1.0.0",
  "description": "将 fnOS Dock 栏从左侧移到底部",
  "author": "eafenzhang",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["*://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "fnOS Dock Bottom"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content-script.js"],
      "css": ["dock.css"],
      "run_at": "document_start"
    }
  ]
}
