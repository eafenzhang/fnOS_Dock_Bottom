{
  "manifest_version": 3,
  "name": "fnOS Dock Bottom",
  "version": "1.0.3",
  "description": "将 fnOS Dock 栏从左侧移到底部 | 每次刷新自动获取最新样式",
  "author": "eafenzhang",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["*://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "fnOS Dock Bottom"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ]
}
